#!/usr/bin/env bash
# brain-dump — Opinionated restic wrapper for AI agent memory backup
# Version: 0.1.0
set -euo pipefail

readonly BB_VERSION="0.2.0"

# Detect script directory (dev mode vs installed mode)
BB_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "$BB_SCRIPT_DIR/lib" ]]; then
  # Dev mode: running from repo checkout
  BB_LIB_DIR="$BB_SCRIPT_DIR/lib"
  BB_PRESET_DIR="$BB_SCRIPT_DIR/presets"
else
  # Installed mode
  BB_LIB_DIR="$HOME/.local/share/brain-dump/lib"
  BB_PRESET_DIR="$HOME/.local/share/brain-dump/presets"
fi

# Source libs
source "$BB_LIB_DIR/output.sh"
source "$BB_LIB_DIR/config.sh"
source "$BB_LIB_DIR/presets.sh"
source "$BB_LIB_DIR/telemetry.sh"

# Override preset dir from lib detection
BB_PRESET_DIR="${BB_PRESET_DIR}"

# Global flags
BB_JSON_MODE="false"
BB_QUIET_MODE="false"
BB_VERBOSE_MODE="false"
BB_CONFIG_FILE="$HOME/.config/brain-dump/config.yaml"

# Export for libs
export BB_JSON_MODE BB_QUIET_MODE BB_VERBOSE_MODE BB_CONFIG_FILE

#######################################
# Usage / help
#######################################
bb::usage() {
  cat <<EOF
brain-dump v${BB_VERSION} — Opinionated restic wrapper for AI agent memory backup

Usage: brain-dump <command> [flags]

Commands:
  init                 Create config and initialize restic repository
  snapshot             Take an incremental backup
  restore              Restore a snapshot
  list                 Show snapshot history
  status               Show backup health
  prune                Apply retention policy
  schedule             Install/remove launchd scheduled backups
  doctor               Check dependencies, config, and health
  telemetry            Show backup telemetry and analytics
  errors               Show quarantined errors
  config               Show resolved configuration

Global flags:
  --config FILE        Path to config file (default: ~/.config/brain-dump/config.yaml)
  --json               Machine-readable JSON output
  --quiet              Suppress all output except errors
  --verbose            Show restic's raw output
  --help               Show this help
  --version            Print version and exit

Run 'brain-dump <command> --help' for command-specific usage.
EOF
}

bb::version() {
  echo "brain-dump v${BB_VERSION}"
}

#######################################
# Check required dependencies
# Returns: 0 if all present, 2 if missing
#######################################
bb::check_deps() {
  local missing=0
  for cmd in restic yq jq; do
    if ! command -v "$cmd" &>/dev/null; then
      bb::output::error "$cmd not found. Install: brew install $cmd"
      missing=1
    fi
  done
  if [[ $missing -eq 1 ]]; then
    return 2
  fi
  return 0
}

#######################################
# COMMAND: init
#######################################
cmd_init() {
  local backend="" bucket="" profile_input=""

  # Parse command flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --backend)
        backend="$2"; shift 2 ;;
      --help)
        cat <<EOF
Usage: brain-dump init [--backend b2|s3|local]

Create config and initialize restic repository.
Interactive if flags not provided.

Flags:
  --backend   Backend type: b2, s3, or local
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump init --help"
        return 1 ;;
    esac
  done

  # Check if config already exists
  if [[ -f "$BB_CONFIG_FILE" ]]; then
    echo "Config exists at $BB_CONFIG_FILE. Overwrite? [y/N]"
    local answer
    read -r answer
    if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
      bb::output::print "Aborted."
      return 0
    fi
  fi

  # Ask backend if not provided
  if [[ -z "$backend" ]]; then
    echo "Backend? [b2/s3/local]"
    read -r backend
  fi

  # Validate backend
  if [[ "$backend" != "b2" && "$backend" != "s3" && "$backend" != "local" ]]; then
    bb::output::error "Invalid backend: $backend. Must be b2, s3, or local."
    return 1
  fi

  local bucket_line="" path_line=""
  if [[ "$backend" == "b2" || "$backend" == "s3" ]]; then
    echo "Bucket name?"
    read -r bucket
    if [[ -z "$bucket" ]]; then
      bb::output::error "Bucket name is required for $backend backend."
      return 1
    fi
    bucket_line="  bucket: ${bucket}"
    if [[ "$backend" == "s3" ]]; then
      echo "Custom endpoint? (leave empty for AWS S3)"
      read -r endpoint
      if [[ -n "$endpoint" ]]; then
        bucket_line="${bucket_line}
  endpoint: ${endpoint}"
      else
        bucket_line="${bucket_line}
  endpoint: \"\""
      fi
    fi
  else
    echo "Local repo path? (must be absolute)"
    read -r local_path
    if [[ -z "$local_path" || "$local_path" != /* ]]; then
      bb::output::error "Local path must be absolute (start with /)."
      return 1
    fi
    path_line="  path: ${local_path}"
  fi

  # Ask profiles
  local available_presets
  available_presets=$(bb::presets::list | tr '\n' ' ')
  echo "Which agent profiles? (space-separated from: ${available_presets})"
  read -r profile_input

  if [[ -z "$profile_input" ]]; then
    bb::output::error "At least one profile is required."
    return 1
  fi

  # Validate presets exist
  local profiles_yaml=""
  for p in $profile_input; do
    if ! bb::presets::exists "$p"; then
      bb::output::error "Unknown preset: '${p}'. Available: ${available_presets}"
      return 1
    fi
    profiles_yaml="${profiles_yaml}
  - name: ${p}
    preset: ${p}
    paths: []
    exclude: []
    include: []"
  done

  # Build config
  local repo_block="  backend: ${backend}"
  if [[ -n "$bucket_line" ]]; then
    repo_block="${repo_block}
${bucket_line}"
  fi
  if [[ -n "$path_line" ]]; then
    repo_block="${repo_block}
${path_line}"
  fi

  local config_content="version: 1
repository:
${repo_block}
profiles:${profiles_yaml}
schedule:
  interval: 3600
retention:
  hourly: 24
  daily: 30
  monthly: 12
  yearly: 0
"

  # Create config dir
  mkdir -p "$(dirname "$BB_CONFIG_FILE")"
  chmod 700 "$(dirname "$BB_CONFIG_FILE")" 2>/dev/null || true

  # Write config
  echo "$config_content" > "$BB_CONFIG_FILE"
  chmod 600 "$BB_CONFIG_FILE" 2>/dev/null || true

  bb::output::print "Config written to $BB_CONFIG_FILE"

  # Validate config
  BB_CONFIG_FILE="$BB_CONFIG_FILE" bb::config::validate || return 1

  # Check credentials
  local cred_ok=true
  if [[ -z "${RESTIC_PASSWORD:-}" ]]; then
    bb::output::print "⚠️  RESTIC_PASSWORD not set. Add to ~/.zshenv:
  export RESTIC_PASSWORD=\"your-encryption-password\""
    cred_ok=false
  fi

  case "$backend" in
    b2)
      if [[ -z "${B2_ACCOUNT_ID:-}" || -z "${B2_ACCOUNT_KEY:-}" ]]; then
        bb::output::print "⚠️  B2_ACCOUNT_ID and/or B2_ACCOUNT_KEY not set. Add to ~/.zshenv:
  export B2_ACCOUNT_ID=\"your-id\"
  export B2_ACCOUNT_KEY=\"your-key\""
        cred_ok=false
      fi
      ;;
    s3)
      if [[ -z "${AWS_ACCESS_KEY_ID:-}" || -z "${AWS_SECRET_ACCESS_KEY:-}" ]]; then
        bb::output::print "⚠️  AWS_ACCESS_KEY_ID and/or AWS_SECRET_ACCESS_KEY not set. Add to ~/.zshenv:
  export AWS_ACCESS_KEY_ID=\"your-id\"
  export AWS_SECRET_ACCESS_KEY=\"your-key\""
        cred_ok=false
      fi
      ;;
  esac

  if [[ "$cred_ok" == "false" ]]; then
    bb::output::print ""
    bb::output::print "Set the above credentials, then run: brain-dump snapshot"
    bb::output::print "The restic repo will be initialized on first snapshot."
    return 0
  fi

  # Try to init restic repo
  bb::config::set_restic_env || return 1

  bb::output::print "Initializing restic repository..."
  if restic init 2>&1; then
    bb::output::print "✅ Ready. Run: brain-dump snapshot"
  else
    local rc=$?
    # Repo may already exist — that's fine
    if restic cat config &>/dev/null; then
      bb::output::print "Repository already initialized. ✅ Ready. Run: brain-dump snapshot"
    else
      bb::output::error "Failed to initialize repository. Check credentials and backend config."
      return $rc
    fi
  fi
}

#######################################
# COMMAND: snapshot
#######################################
cmd_snapshot() {
  local profile_filter="" dry_run="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile) profile_filter="$2"; shift 2 ;;
      --dry-run) dry_run="true"; shift ;;
      --json) BB_JSON_MODE="true"; export BB_JSON_MODE; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump snapshot [--profile NAME] [--dry-run] [--json]

Take an incremental backup.

Flags:
  --profile NAME   Only back up this profile
  --dry-run        Show what would run without executing
  --json           JSON output
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump snapshot --help"
        return 1 ;;
    esac
  done

  bb::check_deps || return 2

  local config
  config=$(bb::config::load) || return 1
  bb::config::validate || return 1
  bb::config::set_restic_env || return 3

  # Resolve profiles
  local all_paths all_excludes
  {
    read -r all_paths
    read -r all_excludes
  } < <(bb::presets::resolve_all "$config" "$profile_filter")

  # Filter to existing paths
  local existing_paths
  existing_paths=$(bb::presets::filter_existing "$all_paths")

  local path_count
  path_count=$(echo "$existing_paths" | jq 'length')

  if [[ "$path_count" -eq 0 ]]; then
    bb::output::error "No backup paths exist on disk. Nothing to back up."
    return 5
  fi

  # Build restic command
  local paths_args=()
  while IFS= read -r p; do
    paths_args+=("$p")
  done < <(echo "$existing_paths" | jq -r '.[]')

  local exclude_args=()
  while IFS= read -r e; do
    exclude_args+=("--exclude" "$e")
  done < <(echo "$all_excludes" | jq -r '.[]')

  # Get profile names for tags
  local profile_names=""
  local count
  count=$(echo "$config" | yq eval '.profiles | length' -)
  local i=0
  while [[ $i -lt $count ]]; do
    local name
    name=$(echo "$config" | yq eval ".profiles[$i].name" -)
    if [[ -n "$profile_filter" && "$name" != "$profile_filter" ]]; then
      i=$((i + 1)); continue
    fi
    if [[ -n "$profile_names" ]]; then
      profile_names="${profile_names},${name}"
    else
      profile_names="$name"
    fi
    i=$((i + 1))
  done

  local tag_args=("--tag" "brain-dump")
  local IFS_OLD="$IFS"
  IFS=','
  for pn in $profile_names; do
    [[ -n "$pn" ]] && tag_args+=("--tag" "$pn")
  done
  IFS="$IFS_OLD"

  # Dry run
  if [[ "$dry_run" == "true" ]]; then
    local cmd_str="restic backup ${paths_args[*]}"
    for e in "${exclude_args[@]}"; do cmd_str="$cmd_str $e"; done
    for t in "${tag_args[@]}"; do cmd_str="$cmd_str $t"; done
    cmd_str="$cmd_str --json"
    bb::output::print "Would run: $cmd_str"
    return 0
  fi

  # Run restic backup
  local start_time
  start_time=$(date +%s)
  local restic_output
  restic_output=$(restic backup "${paths_args[@]}" "${exclude_args[@]}" "${tag_args[@]}" --json 2>/dev/null) || {
    local rc=$?
    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))
    bb::output::verbose "restic stderr: $restic_output"
    bb::output::error "Restic backup failed. Run with --verbose for details."
    bb::telemetry::record_snapshot "unknown" "$duration" 0 0 0 0 0 "$rc" "$profile_names" 0
    bb::telemetry::record_error "snapshot" "Restic backup failed (exit $rc)" "$rc"
    return 4
  }

  # Extract the summary JSON (restic outputs multiple JSON lines; last one is summary)
  local summary_json
  summary_json=$(echo "$restic_output" | grep '"message_type":"summary"' | tail -1) || {
    # Fallback: try last line if grep fails
    summary_json=$(echo "$restic_output" | tail -1)
  }
  # Validate it's parseable JSON
  echo "$summary_json" | jq '.' >/dev/null 2>&1 || {
    bb::output::error "Unexpected restic output. Check restic version."
    return 4
  }

  # Run forget with retention
  local retention_flags
  retention_flags=$(bb::config::retention_flags) || true
  local forget_output
  local pruned=0 kept=0

  if [[ -n "$retention_flags" ]]; then
    forget_output=$(restic forget $retention_flags --prune --tag "brain-dump" --json 2>&1) || {
      bb::output::verbose "forget stderr: $forget_output"
    }
    if [[ -n "$forget_output" ]]; then
      pruned=$(echo "$forget_output" | jq -r '. | if type == "array" then (.[] | select(.tags) | .tags) else . end' 2>/dev/null | wc -l | tr -d ' ')
      # Try to get removed/kept from forget JSON
      local removed_count
      removed_count=$(echo "$forget_output" | jq -r '[.[].tags // empty] | length' 2>/dev/null || echo "0")
      pruned=$(echo "$forget_output" | jq -r 'if type == "object" then (.remove | length) else 0 end' 2>/dev/null || echo "0")
      kept=$(echo "$forget_output" | jq -r 'if type == "object" then (.keep | length) else 0 end' 2>/dev/null || echo "0")
    fi
  fi

  bb::output::snapshot_summary "$summary_json" "$pruned" "$kept" "$profile_names"

  # Record telemetry
  local end_time
  end_time=$(date +%s)
  local duration=$((end_time - start_time))
  local t_snap_id t_files_new t_files_changed t_files_unmod t_bytes_added t_bytes_stored
  t_snap_id=$(echo "$summary_json" | jq -r '.snapshot_id // "unknown"')
  t_files_new=$(echo "$summary_json" | jq -r '.files_new // 0')
  t_files_changed=$(echo "$summary_json" | jq -r '.files_changed // 0')
  t_files_unmod=$(echo "$summary_json" | jq -r '.files_unmodified // 0')
  t_bytes_added=$(echo "$summary_json" | jq -r '.data_added // 0')
  t_bytes_stored=$(echo "$summary_json" | jq -r '.total_bytes_processed // 0')
  bb::telemetry::record_snapshot "$t_snap_id" "$duration" "$t_files_new" "$t_files_changed" "$t_files_unmod" "$t_bytes_added" "$t_bytes_stored" 0 "$profile_names" "$pruned"

  # Clean up old telemetry (30-day retention)
  bb::telemetry::cleanup 30
  bb::telemetry::cleanup_errors 30
}

#######################################
# COMMAND: restore
#######################################
cmd_restore() {
  local snapshot_id="" target="" dry_run="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) target="$2"; shift 2 ;;
      --dry-run) dry_run="true"; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump restore <SNAPSHOT_ID|latest> [--target DIR] [--dry-run]

Restore a snapshot.

Arguments:
  SNAPSHOT_ID   Snapshot ID or 'latest'

Flags:
  --target DIR  Restore to this directory (default: ~/brain-dump-restore-<timestamp>)
  --dry-run     Show what would be restored
EOF
        return 0 ;;
      -*)
        bb::output::error "Unknown flag: $1. See: brain-dump restore --help"
        return 1 ;;
      *)
        if [[ -z "$snapshot_id" ]]; then
          snapshot_id="$1"
        else
          bb::output::error "Unexpected argument: $1"
          return 1
        fi
        shift ;;
    esac
  done

  if [[ -z "$snapshot_id" ]]; then
    bb::output::error "Usage: brain-dump restore <SNAPSHOT_ID|latest> [--target DIR]"
    return 1
  fi

  bb::check_deps || return 2
  bb::config::set_restic_env || return 3

  # Default target
  if [[ -z "$target" ]]; then
    target="$HOME/brain-dump-restore-$(date +%Y%m%d-%H%M%S)"
  fi

  bb::output::print "⚠️  This will write files to ${target}. It will NOT overwrite your current agent files."

  local dry_flag=""
  if [[ "$dry_run" == "true" ]]; then
    dry_flag="--dry-run"
  fi

  if restic restore "$snapshot_id" --target "$target" $dry_flag 2>&1; then
    bb::output::print "✅ Restored to ${target}. To use: cp -r ${target}/<agent-dir> ~/<agent-dir>"
  else
    local rc=$?
    bb::output::error "Restore failed. Check snapshot ID and target directory."
    return 4
  fi
}

#######################################
# COMMAND: list
#######################################
cmd_snapshot_list() {
  local latest="" profile_filter=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --latest) latest="$2"; shift 2 ;;
      --profile) profile_filter="$2"; shift 2 ;;
      --json) BB_JSON_MODE="true"; export BB_JSON_MODE; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump list [--latest N] [--profile NAME] [--json]

Show snapshot history.

Flags:
  --latest N      Show last N snapshots
  --profile NAME  Filter by profile tag
  --json          JSON output
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump list --help"
        return 1 ;;
    esac
  done

  bb::check_deps || return 2
  bb::config::set_restic_env || return 3

  local tag_args=("--tag" "brain-dump")
  if [[ -n "$profile_filter" ]]; then
    tag_args+=("--tag" "$profile_filter")
  fi

  local snapshots
  snapshots=$(restic snapshots "${tag_args[@]}" --json 2>&1) || {
    local rc=$?
    bb::output::error "Failed to list snapshots."
    return 4
  }

  # Filter to only brain-dump tagged
  if [[ -n "$profile_filter" ]]; then
    snapshots=$(echo "$snapshots" | jq --arg pf "$profile_filter" '[.[] | select(.tags | index($pf))]')
  fi

  # Apply --latest
  if [[ -n "$latest" ]]; then
    snapshots=$(echo "$snapshots" | jq --argjson n "$latest" '.[-$n:]')
  fi

  bb::output::snapshot_list "$snapshots"
}

#######################################
# COMMAND: status
#######################################
cmd_status() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) BB_JSON_MODE="true"; export BB_JSON_MODE; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump status [--json]

Show backup health.

Flags:
  --json   JSON output
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump status --help"
        return 1 ;;
    esac
  done

  bb::check_deps || return 2

  local config
  config=$(bb::config::load) || return 1

  local backend bucket_val
  backend=$(echo "$config" | yq eval '.repository.backend' -)
  bucket_val=$(echo "$config" | yq eval '.repository.bucket // ""' -)

  # Check repo reachable
  local repo_reachable="false"
  bb::config::set_restic_env &>/dev/null || true
  if restic cat config &>/dev/null; then
    repo_reachable="true"
  fi

  # Latest snapshot
  local last_id="none" last_time="never" age_seconds=0 age_human="N/A" total_snapshots=0
  if [[ "$repo_reachable" == "true" ]]; then
    local snap_json
    snap_json=$(restic snapshots --tag "brain-dump" --json 2>/dev/null || echo "[]")
    total_snapshots=$(echo "$snap_json" | jq 'length')
    local snap_count
    snap_count=$total_snapshots
    if [[ "$snap_count" -gt 0 ]]; then
      # Get the LAST snapshot (most recent) — restic returns oldest-first
      last_id=$(echo "$snap_json" | jq -r '.[-1].id[:8]')
      last_time=$(echo "$snap_json" | jq -r '.[-1].time')
      local now_iso
      now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
      age_seconds=$(jq -n --arg t "$last_time" --arg n "$now_iso" '(($n | strptime("%Y-%m-%dT%H:%M:%SZ") | mktime) - ($t | split(".")[0] | strptime("%Y-%m-%dT%H:%M:%S") | mktime)) | if . < 0 then 0 else . end' 2>/dev/null || echo "0")
      age_human=$(bb::output::human_age "$age_seconds" 2>/dev/null || echo "N/A")
    fi
  fi

  # Repo stats
  local total_stored=0 total_stored_human="N/A"
  if [[ "$repo_reachable" == "true" ]]; then
    local stats_json
    stats_json=$(restic stats --json 2>/dev/null || echo "{}")
    total_stored=$(echo "$stats_json" | jq -r '.total_size // 0')
    total_stored_human=$(bb::output::human_bytes "$total_stored" 2>/dev/null || echo "N/A")
  fi

  # Schedule status
  local schedule_installed="false" interval_seconds=3600 interval_human="N/A"
  local plist_path="$HOME/Library/LaunchAgents/com.brain-dump.plist"
  if [[ -f "$plist_path" ]]; then
    schedule_installed="true"
    interval_seconds=$(echo "$config" | yq eval '.schedule.interval // 3600' -)
    local interval_h=$((interval_seconds / 3600))
    interval_human="every ${interval_h} hour(s)"
  fi

  # Build JSON
  local status_json
  status_json=$(jq -n \
    --argjson reachable "$repo_reachable" \
    --arg backend "$backend" \
    --arg bucket "$bucket_val" \
    --arg last_id "$last_id" \
    --arg last_time "$last_time" \
    --argjson age_secs "$age_seconds" \
    --arg age_human "$age_human" \
    --argjson total_snapshots "$total_snapshots" \
    --argjson total_stored "$total_stored" \
    --arg total_stored_human "$total_stored_human" \
    --argjson sched_installed "$schedule_installed" \
    --argjson interval_secs "$interval_seconds" \
    --arg interval_human "$interval_human" \
    '{
      repo_reachable: $reachable,
      backend: $backend,
      bucket: $bucket,
      last_snapshot: {
        id: $last_id,
        time: $last_time,
        age_seconds: $age_secs,
        age_human: $age_human
      },
      total_snapshots: $total_snapshots,
      total_stored_bytes: $total_stored,
      total_stored_human: $total_stored_human,
      schedule: {
        installed: $sched_installed,
        interval_seconds: $interval_secs,
        interval_human: $interval_human
      }
    }')

  bb::output::status_summary "$status_json"
}

#######################################
# COMMAND: prune
#######################################
cmd_prune() {
  local dry_run="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run="true"; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump prune [--dry-run]

Apply retention policy from config.

Flags:
  --dry-run   Show what would be pruned
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump prune --help"
        return 1 ;;
    esac
  done

  bb::check_deps || return 2
  bb::config::set_restic_env || return 3

  local retention_flags
  retention_flags=$(bb::config::retention_flags)
  if [[ -z "$retention_flags" ]]; then
    bb::output::print "No retention policy configured. Nothing to prune."
    return 0
  fi

  local dry_flag=""
  if [[ "$dry_run" == "true" ]]; then
    dry_flag="--dry-run"
  fi

  local output
  output=$(restic forget $retention_flags $dry_flag --prune --tag "brain-dump" --json 2>&1) || {
    local rc=$?
    bb::output::error "Prune failed."
    return 4
  }

  local removed
  removed=$(echo "$output" | jq -r 'if type == "object" then (.remove | length) else 0 end' 2>/dev/null | tr -d '\n' | head -1 || echo "0")
  # Ensure removed is a clean integer
  removed=$(echo "$removed" | grep -oE '^[0-9]+' || echo "0")

  if [[ "$removed" -eq 0 ]]; then
    bb::output::print "Nothing to prune."
  else
    bb::output::print "Removed ${removed} snapshot(s)."
  fi
}

#######################################
# COMMAND: schedule
#######################################
cmd_schedule() {
  local subcmd="${1:-}"
  shift || true

  case "$subcmd" in
    install)
      cmd_schedule_install "$@" ;;
    remove)
      cmd_schedule_remove "$@" ;;
    status)
      cmd_schedule_status "$@" ;;
    "")
      bb::output::error "Usage: brain-dump schedule <install|remove|status>"
      return 1 ;;
    --help)
      cat <<EOF
Usage: brain-dump schedule <install|remove|status>

Manage launchd scheduled backups.

Subcommands:
  install   Install launchd job
  remove    Remove launchd job
  status    Show schedule status
EOF
      return 0 ;;
    *)
      bb::output::error "Unknown subcommand: $subcmd. Use: install, remove, or status"
      return 1 ;;
  esac
}

cmd_schedule_install() {
  local plist_path="$HOME/Library/LaunchAgents/com.brain-dump.plist"

  if [[ -f "$plist_path" ]]; then
    bb::output::error "Schedule already installed. Run: brain-dump schedule remove first, then install again."
    return 1
  fi

  local config
  config=$(bb::config::load) || return 1

  local interval
  interval=$(echo "$config" | yq eval '.schedule.interval // 3600' -)

  # Find script location
  local script_path
  if [[ -L "$HOME/.local/bin/brain-dump" ]]; then
    script_path="$(cd "$(dirname "$HOME/.local/bin/brain-dump")" && pwd)/brain-dump"
  else
    script_path="$BB_SCRIPT_DIR/brain-dump"
    # If running from dev, use the dev script
    if [[ ! -f "$script_path" ]]; then
      script_path="$HOME/.local/bin/brain-dump"
    fi
  fi

  # Determine install_dir for plist
  local install_dir
  install_dir="$(dirname "$script_path")"

  # Generate plist from template
  local template
  if [[ -f "$BB_SCRIPT_DIR/launchd/com.brain-dump.plist.template" ]]; then
    template=$(cat "$BB_SCRIPT_DIR/launchd/com.brain-dump.plist.template")
  else
    template=$(cat "$HOME/.local/share/brain-dump/launchd/com.brain-dump.plist.template" 2>/dev/null) || {
      bb::output::error "plist template not found."
      return 1
    }
  fi

  # Substitute template vars
  local plist_content
  plist_content=$(echo "$template" | \
    sed "s|{{INSTALL_DIR}}|${install_dir}|g" | \
    sed "s|{{INTERVAL_SECONDS}}|${interval}|g" | \
    sed "s|{{HOME}}|${HOME}|g")

  # Write plist
  mkdir -p "$(dirname "$plist_path")"
  echo "$plist_content" > "$plist_path"

  # Load with launchctl
  local uid
  uid=$(id -u)
  launchctl bootstrap "gui/${uid}" "$plist_path" 2>&1 || {
    # Already loaded? Try bootout + bootstrap
    launchctl bootout "gui/${uid}/com.brain-dump" 2>/dev/null || true
    launchctl bootstrap "gui/${uid}" "$plist_path" 2>&1
  }

  local interval_h=$((interval / 3600))
  bb::output::print "✅ Scheduled every ${interval_h} hour(s). Next run at login or after interval."
}

cmd_schedule_remove() {
  local plist_path="$HOME/Library/LaunchAgents/com.brain-dump.plist"
  local uid
  uid=$(id -u)

  if [[ ! -f "$plist_path" ]]; then
    bb::output::print "No schedule found."
    return 0
  fi

  launchctl bootout "gui/${uid}/com.brain-dump" 2>/dev/null || true
  rm -f "$plist_path"
  bb::output::print "✅ Schedule removed."
}

cmd_schedule_status() {
  local plist_path="$HOME/Library/LaunchAgents/com.brain-dump.plist"

  if [[ -f "$plist_path" ]]; then
    local interval
    interval=$(plutil -extract StartInterval raw "$plist_path" 2>/dev/null || echo "3600")
    local interval_h=$((interval / 3600))
    bb::output::print "Schedule: ✅ installed (every ${interval_h} hour(s))"

    # Check last run from log
    if [[ -f /tmp/brain-dump.log ]]; then
      local last_line
      last_line=$(tail -1 /tmp/brain-dump.log 2>/dev/null || echo "")
      if [[ -n "$last_line" ]]; then
        bb::output::print "Last run output: $last_line"
      fi
    fi
  else
    bb::output::print "Schedule: not installed"
  fi
}

#######################################
# COMMAND: doctor
#######################################
cmd_doctor() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) BB_JSON_MODE="true"; export BB_JSON_MODE; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump doctor [--json]

Run 10-point health check:
  1. bash version
  2. restic installed
  3. yq installed
  4. jq installed
  5. config file valid
  6. encryption password set
  7. backend credentials
  8. repository reachable
  9. profile paths exist
  10. schedule installed + recent backup
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump doctor --help"
        return 1 ;;
    esac
  done

  # Collect check results as JSON lines
  local check_lines=""
  local all_pass=true
  local critical_fail=false
  local config_ok=true

  # Helper to append a JSON line
  _dc() { check_lines="${check_lines}${1}\n"; }

  # 1. bash version
  local bash_ver
  bash_ver=$(bash --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "0.0.0")
  local bash_major bash_minor
  bash_major=$(echo "$bash_ver" | cut -d. -f1)
  bash_minor=$(echo "$bash_ver" | cut -d. -f2)
  if [[ "$bash_major" -gt 3 ]] || { [[ "$bash_major" -eq 3 ]] && [[ "$bash_minor" -ge 2 ]]; }; then
    _dc "{\"name\":\"bash\",\"status\":\"pass\",\"version\":\"${bash_ver}\",\"required\":\"3.2+\"}"
  else
    _dc "{\"name\":\"bash\",\"status\":\"fail\",\"version\":\"${bash_ver}\",\"required\":\"3.2+\"}"
    all_pass=false; critical_fail=true
  fi

  # 2-4. Deps: restic, yq, jq
  local _dn _dv _dr _dcmd
  for _de in "restic|restic version|0.16+" "yq|yq --version|4.0+" "jq|jq --version|1.6+"; do
    _dn="${_de%%|*}"; _dr="${_de##*|}"; _dcmd="${_de#*|}"; _dcmd="${_dcmd%|*}"
    _dv=$(eval "$_dcmd" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1 || true)
    if command -v "$_dn" &>/dev/null && [[ -n "$_dv" ]]; then
      _dc "{\"name\":\"${_dn}\",\"status\":\"pass\",\"version\":\"${_dv}\",\"required\":\"${_dr}\"}"
    else
      _dc "{\"name\":\"${_dn}\",\"status\":\"fail\",\"detail\":\"not found\",\"required\":\"${_dr}\"}"
      all_pass=false; critical_fail=true
    fi
  done

  # 5. Config file
  if [[ -f "$BB_CONFIG_FILE" ]]; then
    if bb::config::validate &>/dev/null; then
      _dc '{"name":"config","status":"pass","detail":"valid"}'
    else
      _dc '{"name":"config","status":"fail","detail":"schema invalid"}'
      all_pass=false; config_ok=false
    fi
  else
    _dc '{"name":"config","status":"fail","detail":"file not found at ~/.config/brain-dump/config.yaml"}'
    all_pass=false; config_ok=false
  fi

  # 6. RESTIC_PASSWORD
  if [[ -n "${RESTIC_PASSWORD:-}" ]]; then
    _dc '{"name":"encryption","status":"pass","detail":"RESTIC_PASSWORD set"}'
  else
    _dc '{"name":"encryption","status":"fail","detail":"RESTIC_PASSWORD not set. Add to ~/.zshenv"}'
    all_pass=false
  fi

  # 7-10. Only if config is valid
  if [[ "$config_ok" == "true" ]]; then
    # 7. Backend credentials
    local backend
    backend=$(bb::config::get '.repository.backend' 2>/dev/null || echo "")
    case "$backend" in
      b2)
        if [[ -n "${B2_ACCOUNT_ID:-}" && -n "${B2_ACCOUNT_KEY:-}" ]]; then
          _dc '{"name":"backend_credentials","status":"pass","detail":"B2 credentials set"}'
        else
          _dc '{"name":"backend_credentials","status":"fail","detail":"B2 credentials missing. Add B2_ACCOUNT_ID and B2_ACCOUNT_KEY to ~/.zshenv"}'
          all_pass=false
        fi ;;
      s3)
        if [[ -n "${AWS_ACCESS_KEY_ID:-}" && -n "${AWS_SECRET_ACCESS_KEY:-}" ]]; then
          _dc '{"name":"backend_credentials","status":"pass","detail":"AWS credentials set"}'
        else
          _dc '{"name":"backend_credentials","status":"fail","detail":"AWS credentials missing"}'
          all_pass=false
        fi ;;
      local)
        _dc '{"name":"backend_credentials","status":"pass","detail":"local backend (no credentials needed)"}' ;;
    esac

    # 8. Repo reachable
    bb::config::set_restic_env &>/dev/null || true
    if restic cat config &>/dev/null; then
      _dc '{"name":"repo","status":"pass","detail":"reachable"}'
    else
      _dc '{"name":"repo","status":"fail","detail":"unreachable. Check credentials and backend config"}'
      all_pass=false
    fi

    # 9. Profile paths
    local config_yaml
    config_yaml=$(bb::config::load 2>/dev/null) || config_yaml=""
    if [[ -n "$config_yaml" ]]; then
      local resolved_paths resolved_existing
      resolved_paths=$(bb::presets::resolve_all "$config_yaml" "" 2>/dev/null | head -1 || echo "[]")
      resolved_existing=$(bb::presets::filter_existing "$resolved_paths" 2>/dev/null || echo "[]")
      local total_n exist_n
      total_n=$(echo "$resolved_paths" | jq 'length' 2>/dev/null || echo "0")
      exist_n=$(echo "$resolved_existing" | jq 'length' 2>/dev/null || echo "0")
      if [[ "$exist_n" -gt 0 ]]; then
        _dc "{\"name\":\"paths\",\"status\":\"pass\",\"detail\":\"${exist_n}/${total_n} profiles have existing paths\"}"
      else
        _dc "{\"name\":\"paths\",\"status\":\"fail\",\"detail\":\"${exist_n}/${total_n} profiles have existing paths\"}"
        all_pass=false
      fi
    fi

    # 10. Schedule + recent backup
    local plist_path="$HOME/Library/LaunchAgents/com.brain-dump.plist"
    local sched_ok=false
    local sched_detail=""

    if [[ -f "$plist_path" ]]; then
      # Check launchd loaded
      if launchctl list 2>/dev/null | grep -q "com.brain-dump"; then
        sched_ok=true

        # Check last backup freshness
        local snap_json
        snap_json=$(restic snapshots --tag "brain-dump" --json 2>/dev/null || echo "[]")
        local snap_count
        snap_count=$(echo "$snap_json" | jq 'length')
        if [[ "$snap_count" -gt 0 ]]; then
          local last_time
          last_time=$(echo "$snap_json" | jq -r '.[-1].time')
          local now_iso
          now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
          local age_seconds
          age_seconds=$(jq -n --arg t "$last_time" --arg n "$now_iso" '(($n | strptime("%Y-%m-%dT%H:%M:%SZ") | mktime) - ($t | split(".")[0] | strptime("%Y-%m-%dT%H:%M:%S") | mktime)) | if . < 0 then 0 else . end' 2>/dev/null || echo "999999")
          local max_age=$((4 * 3600))  # 4 hours
          if [[ "$age_seconds" -lt "$max_age" ]]; then
            local age_min=$((age_seconds / 60))
            sched_detail="installed, last backup ${age_min} min ago"
          else
            local age_h=$((age_seconds / 3600))
            sched_detail="installed, but last backup ${age_h}h ago (stale!)"
            sched_ok=false
          fi
        else
          sched_detail="installed, but no snapshots found"
          sched_ok=false
        fi
      else
        sched_detail="plist exists but not loaded in launchd"
      fi
    else
      sched_detail="not installed. Run: brain-dump schedule install"
    fi

    if [[ "$sched_ok" == "true" ]]; then
      _dc "{\"name\":\"schedule\",\"status\":\"pass\",\"detail\":\"${sched_detail}\"}"
    else
      _dc "{\"name\":\"schedule\",\"status\":\"fail\",\"detail\":\"${sched_detail}\"}"
      all_pass=false
    fi

    # 11. Disk space check (bonus)
    local disk_available
    disk_available=$(df -k "$HOME" | tail -1 | awk '{print $4}')
    local disk_gb=$((disk_available / 1024 / 1024))
    if [[ "$disk_gb" -gt 5 ]]; then
      _dc "{\"name\":\"disk_space\",\"status\":\"pass\",\"detail\":\"${disk_gb}GB available\"}"
    else
      _dc "{\"name\":\"disk_space\",\"status\":\"fail\",\"detail\":\"only ${disk_gb}GB available (need >5GB)\"}"
      all_pass=false
    fi
  fi

  # Build final JSON array
  local checks
  checks=$(printf '%b' "$check_lines" | tr -d '\000-\037' | jq -s '.')
  local pass_count fail_count
  pass_count=$(echo "$checks" | jq '[.[] | select(.status == "pass")] | length')
  fail_count=$(echo "$checks" | jq '[.[] | select(.status == "fail")] | length')
  local total_count
  total_count=$(echo "$checks" | jq 'length')

  local results
  results=$(jq -n --argjson checks "$checks" --argjson all_pass "$all_pass" --argjson pass_count "$pass_count" --argjson fail_count "$fail_count" --argjson total_count "$total_count" '{checks: $checks, all_pass: $all_pass, passed: $pass_count, failed: $fail_count, total: $total_count}')

  bb::output::doctor_results "$results"

  if [[ "$critical_fail" == "true" ]]; then
    return 2
  elif [[ "$all_pass" == "false" ]]; then
    return 1
  fi
  return 0
}

#######################################
# COMMAND: config
#######################################
cmd_config() {
  local path_key=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path) path_key="$2"; shift 2 ;;
      --help)
        cat <<EOF
Usage: brain-dump config [--path KEY]

Show resolved configuration.

Flags:
  --path KEY   Extract a single config value (yq path, e.g. .repository.backend)
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump config --help"
        return 1 ;;
    esac
  done

  bb::check_deps || return 2

  if [[ -n "$path_key" ]]; then
    bb::config::get "$path_key"
  else
    bb::config::load
  fi
}

#######################################
# COMMAND: telemetry
#######################################
cmd_telemetry() {
  local max_entries=20 filter="" show_json="false" show_stats="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --last) max_entries="$2"; shift 2 ;;
      --query) filter="$2"; shift 2 ;;
      --stats) show_stats="true"; shift ;;
      --json) show_json="true"; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump telemetry [--last N] [--query FILTER] [--stats] [--json]

Show backup telemetry and analytics.

Flags:
  --last N        Show last N entries (default: 20, 0=all)
  --query FILTER  jq filter expression (e.g. 'exit_code == 0')
  --stats         Show summary statistics
  --json          Raw JSON output
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump telemetry --help"
        return 1 ;;
    esac
  done

  # Stats mode
  if [[ "$show_stats" == "true" ]]; then
    local stats
    stats=$(bb::telemetry::stats)
    if [[ "$show_json" == "true" ]]; then
      echo "$stats"
    else
      local total_snap total_err total_bytes avg_dur last_snap
      total_snap=$(echo "$stats" | jq -r '.total_snapshots')
      total_err=$(echo "$stats" | jq -r '.total_errors')
      total_bytes=$(bb::output::human_bytes "$(echo "$stats" | jq -r '.total_bytes_added')")
      avg_dur=$(echo "$stats" | jq -r '.avg_duration_seconds')
      last_snap=$(echo "$stats" | jq -r '.last_snapshot')

      echo "Telemetry Summary:"
      echo "  Total snapshots: ${total_snap}"
      echo "  Total errors: ${total_err}"
      echo "  Total bytes added: ${total_bytes}"
      echo "  Avg duration: ${avg_dur}s"
      echo "  Last snapshot: ${last_snap}"
    fi
    return 0
  fi

  # Query mode
  local entries
  entries=$(bb::telemetry::query "$max_entries" "$filter")

  if [[ "$show_json" == "true" ]]; then
    echo "$entries" | jq -s '.'
  else
    local count
    count=$(echo "$entries" | grep -c '.' 2>/dev/null || echo 0)
    if [[ "$count" -eq 0 || "$entries" == "[]" ]]; then
      echo "No telemetry entries found."
      return 0
    fi

    echo "Last ${max_entries} telemetry entries:"
    echo ""
    echo "$entries" | jq -r '. | "\(.timestamp) | \(.snapshot_id[:8] // "unknown") | \(.duration_seconds)s | \(.files_new) new | +\(.bytes_added) bytes | \(if .exit_code == 0 then "✅" else "❌" end)"' 2>/dev/null
  fi
}

#######################################
# COMMAND: errors
#######################################
cmd_errors() {
  local max_entries=10 clear_errors="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --last) max_entries="$2"; shift 2 ;;
      --clear) clear_errors="true"; shift ;;
      --help)
        cat <<EOF
Usage: brain-dump errors [--last N] [--clear]

Show quarantined errors.

Flags:
  --last N   Show last N errors (default: 10)
  --clear    Clear all quarantined errors
EOF
        return 0 ;;
      *)
        bb::output::error "Unknown flag: $1. See: brain-dump errors --help"
        return 1 ;;
    esac
  done

  local err_dir
  err_dir="${HOME}/.brain-dump/errors"

  # Clear mode
  if [[ "$clear_errors" == "true" ]]; then
    if [[ -d "$err_dir" ]]; then
      rm -f "$err_dir"/*.json 2>/dev/null
      echo "✅ Cleared all quarantined errors."
    else
      echo "No errors directory found."
    fi
    return 0
  fi

  # List mode
  if [[ ! -d "$err_dir" ]] || [[ -z "$(ls -A "$err_dir" 2>/dev/null)" ]]; then
    echo "No quarantined errors found. ✅"
    return 0
  fi

  echo "Quarantined errors (last ${max_entries}):"
  echo ""
  ls -t "$err_dir"/*.json 2>/dev/null | head -n "$max_entries" | while read -r f; do
    local ts op msg code
    ts=$(jq -r '.timestamp' "$f" 2>/dev/null || echo "unknown")
    op=$(jq -r '.operation' "$f" 2>/dev/null || echo "unknown")
    msg=$(jq -r '.error' "$f" 2>/dev/null || echo "unknown")
    code=$(jq -r '.exit_code' "$f" 2>/dev/null || echo "1")
    echo "  ❌ ${ts} | ${op} | exit ${code} | ${msg}"
  done
}

#######################################
# Main entry point — parse globals and route to commands
#######################################
main() {
  local command=""

  if [[ $# -eq 0 ]]; then
    bb::usage
    exit 0
  fi

  # Parse global flags first
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        BB_CONFIG_FILE="$2"
        export BB_CONFIG_FILE
        shift 2 ;;
      --json)
        BB_JSON_MODE="true"
        export BB_JSON_MODE
        shift ;;
      --quiet)
        BB_QUIET_MODE="true"
        export BB_QUIET_MODE
        shift ;;
      --verbose)
        BB_VERBOSE_MODE="true"
        export BB_VERBOSE_MODE
        shift ;;
      --version)
        bb::version
        exit 0 ;;
      --help)
        bb::usage
        exit 0 ;;
      --*)
        echo "Unknown flag: $1. See: brain-dump --help" >&2
        exit 1 ;;
      *)
        command="$1"
        shift
        break ;;
    esac
  done

  # Route to command
  case "$command" in
    init)      cmd_init "$@" ;;
    snapshot)  cmd_snapshot "$@" ;;
    restore)   cmd_restore "$@" ;;
    list)      cmd_snapshot_list "$@" ;;
    status)    cmd_status "$@" ;;
    prune)     cmd_prune "$@" ;;
    schedule)  cmd_schedule "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    telemetry) cmd_telemetry "$@" ;;
    errors)    cmd_errors "$@" ;;
    config)    cmd_config "$@" ;;
    *)
      bb::output::error "Unknown command: $command. Run: brain-dump --help"
      exit 1 ;;
  esac
}

main "$@"
